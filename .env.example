# ─── Copy this file to .env and fill in your keys ───────────────────────────
# .env is gitignored. Never paste keys into source files.

# ── Provider selection ────────────────────────────────────────────────────────
# Which model provider to use: claude | openai | ollama
TRILLION_PROVIDER=claude

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# ── OpenAI (or OpenRouter) ────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
# For OpenRouter, set this and use an OpenRouter model string:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
# OPENAI_MODEL=anthropic/claude-opus-4

# ── Ollama (local, Raspberry Pi) ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Voice V1: Deepgram STT (cloud) + Piper TTS (local, free) ─────────────────
# Get a Deepgram key at https://console.deepgram.com/signup (free trial credit)
# DEEPGRAM_API_KEY=...
# TTS runs fully offline via Piper — no API key needed. Voice model is
# downloaded to voices/ (see README/HANDOFF for the download command).
# Only set this if you want a different voice than the default.
# PIPER_VOICE_PATH=voices/en_US-amy-medium.onnx

# ── Tier 4: Memory ────────────────────────────────────────────────────────────
# NOTES_PATH=~/notes             # path to your local markdown notes folder

# ── Tier 5: Heartbeat ────────────────────────────────────────────────────────
# HEARTBEAT_INTERVAL_SECONDS=300
# QUIET_HOURS_START=22           # 10 PM
# QUIET_HOURS_END=8              # 8 AM

# ── Cost dashboard ────────────────────────────────────────────────────────────
# Where the local usage/cost database is written (SQLite file).
# TRILLION_USAGE_DB=usage.db
# Port the web server (serve.py) listens on.
# TRILLION_WEB_PORT=8123
# Soft monthly budget in USD. When set, the cost indicator turns amber at 80%
# and red at 100%. Leave unset to disable the budget alert. (It's an alert, not
# a hard cap — spending is never blocked.)
# TRILLION_MONTHLY_BUDGET_USD=50
